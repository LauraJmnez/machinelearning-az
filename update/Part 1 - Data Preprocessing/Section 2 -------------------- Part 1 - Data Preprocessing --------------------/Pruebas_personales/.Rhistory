endpoint <- "http://155.54.239.183:3036/blazegraph/Kb"
#Query 1. Query 1. Protein participating in the biological
#process “Lipid transport”.
prefix owl: <http://www.w3.org/2002/01/rdf-schema#>
#Query 1. Query 1. Protein participating in the biological
#process “Lipid transport”.
query1 <- "prefix owl: <http://www.w3.org/2002/01/rdf-schema#>
prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix up: <http://purl.uniprot.org/core/>
prefix biotop: <http://purl.org/biotop/biotop.owl#>
select ?type ?Protein_name
where {
?pID rdf:type ?type .
?pID owl:sameAs ?Protein_name .
?pID biotop:participatesIn ?MFunction .
?MFunction up:partOf ?BioProcessID .
?BioProcessID rdf:type 'Lipid transport' .
}
"
q1 <- SPARQL(endpoint,query1)
q1$results
q1 <- SPARQL(endpoint,query1)
