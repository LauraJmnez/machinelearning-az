query3 <- "prefix owl: <http://www.w3.org/2002/01/rdf-schema#>
prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix up: <http://purl.uniprot.org/core/>
prefix biotop: <http://purl.org/biotop/biotop.owl#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
select ?type ?Protein_name ?Label ?Molecular_function ?Biological_process
where {
?pID rdf:type ?type .
?pID owl:sameAs ?Protein_name .
?pID rdfs:label ?Label .
?pID up:organism 'Homo sapiens' .
?pID biotop:participatesIn ?MFunctionID .
?MFunctionID rdf:type ?Molecular_function .
?MFunctionID up:partOf ?BioProcessID .
?BioProcessID rdf:type ?Biological_process .
}
"
q3 <- SPARQL(endpoint, query3)
q3$results
query4 <- "prefix owl: <http://www.w3.org/2002/01/rdf-schema#>
prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix up: <http://purl.uniprot.org/core/>
prefix biotop: <http://purl.org/biotop/biotop.owl#>
select ?Molecular_function ?Protein_name ?type ?Organim
where {
?pID rdf:type ?type .
?pID owl:sameAs ?Protein_name .
?pID up:organism ?Organism .
?pID biotop:participatesIn ?MFunction .
?MFunction rdf:type ?Molecular_function .
}
"
q4 <- SPARQL(endpoint,query4)
q4$results
query5 <- "prefix owl: <http://www.w3.org/2002/01/rdf-schema#>
prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix up: <http://purl.uniprot.org/core/>
prefix biotop: <http://purl.org/biotop/biotop.owl#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
select ?type ?Molecular_function ?Biological_process ?Organism
where {
?pID rdf:type ?type .
?pID owl:sameAs 'ompN' .
?pID up:organism ?Organism .
?pID biotop:participatesIn ?MFunctionID .
?MFunctionID rdf:type ?Molecular_function .
?MFunctionID up:partOf ?BioProcessID .
?BioProcessID rdf:type ?Biological_process .
}
"
q5 <- SPARQL(endpoint,query5)
q5$results
